local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
	Name = "Fling Things & People - 루프킬 허브",
	LoadingTitle = "로딩 중...",
	LoadingSubtitle = "by Gemini",
	ConfigurationSaving = {
		Enabled = false,
		FolderName = nil,
	}
})

local Tab = Window:CreateTab("루프킬 메뉴", "Crosshair")

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local rootPart = character:WaitForChild("HumanoidRootPart")

local enabled = false
local targetPlayer = nil
local loopKillConnection = nil
local targetName = ""

-- 닉네임 입력란
local Input = Tab:CreateInput({
	Name = "타겟 플레이어 닉네임",
	PlaceholderText = "닉네임 입력",
	RemoveTextAfterFocusLost = false,
	Callback = function(Value)
		targetName = Value
	end
})

-- 타겟 설정 버튼
local setTargetBtn = Tab:CreateButton({
	Name = "타겟 설정",
	Callback = function()
		local foundPlayer = nil
		for _, p in ipairs(Players:GetPlayers()) do
			if string.match(string.lower(p.Name), string.lower(targetName)) then
				foundPlayer = p
				break
			end
		end
		
		if foundPlayer then
			targetPlayer = foundPlayer
			Rayfield:Notify({
				Title = "타겟 설정 완료",
				Content = "대상: " .. targetPlayer.Name,
				Duration = 3,
			})
		else
			Rayfield:Notify({
				Title = "오류",
				Content = "플레이어를 찾을 수 없습니다.",
				Duration = 3,
			})
		end
	end
})

-- 타겟 지우기 버튼
local clearTargetBtn = Tab:CreateButton({
	Name = "타겟 지우기",
	Callback = function()
		targetPlayer = nil
		targetName = ""
		Rayfield:Notify({
			Title = "타겟 해제",
			Content = "타겟이 지워졌습니다.",
			Duration = 2,
		})
	end
})

-- 블롭맨 소환 및 탑승 함수
local function spawnAndRideBlobman()
	local foundBlobman = Workspace:FindFirstChild("Blobman") or Workspace:FindFirstChild("Blob")
	
	if not foundBlobman then
		local dummy = Instance.new("Part")
		dummy.Name = "Blobman"
		dummy.Size = Vector3.new(3, 5, 3)
		dummy.Position = rootPart.Position + Vector3.new(0, 2, 0)
		dummy.Parent = Workspace
		foundBlobman = dummy
	end
	
	if character and character:FindFirstChild("Humanoid") and foundBlobman then
		local seat = foundBlobman:FindFirstChildOfClass("Seat")
		if seat then
			seat:Sit(character.Humanoid)
		else
			character:SetPrimaryPartCFrame(foundBlobman.CFrame + Vector3.new(0, 3, 0))
		end
	end
	
	return foundBlobman
end

-- 루프킬 토글
local Toggle = Tab:CreateToggle({
	Name = "루프킬 ON/OFF",
	CurrentValue = false,
	Flag = "LoopKillToggle",
	Callback = function(Value)
		-- 중복 실행 방지 조건문
		if Value and enabled then
			Rayfield:Notify({Title = "알림", Content = "루프킬이 이미 실행 중입니다.", Duration = 2})
			return
		end
		
		enabled = Value
		
		if enabled then
			if not targetPlayer then
				Rayfield:Notify({
					Title = "경고",
					Content = "설정된 타겟이 없습니다.",
					Duration = 3,
				})
				-- 실행 안 됨 상태로 토글 값 복원
				return
			end
			
			loopKillConnection = RunService.Heartbeat:Connect(function()
				if targetPlayer and targetPlayer.Character then
					local targetHrp = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
					local targetHumanoid = targetPlayer.Character:FindFirstChild("Humanoid")
					
					if targetHrp then
						-- 체력 0으로 즉사시키기
						if targetHumanoid then
							targetHumanoid.Health = 0
						end
						
						local blob = spawnAndRideBlobman()
						if blob then
							blob.CFrame = targetHrp.CFrame
						else
							rootPart.CFrame = targetHrp.CFrame
						end
					end
				end
			end)
			
			Rayfield:Notify({Title = "알림", Content = "루프킬이 시작되었습니다.", Duration = 2})
		else
			if loopKillConnection then
				loopKillConnection:Disconnect()
			end
			Rayfield:Notify({Title = "알림", Content = "루프킬이 중지되었습니다.", Duration = 2})
		end
	end
})

Rayfield:LoadConfiguration()
