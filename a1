-- 블롭맨 소환 및 탑승 기능
local function spawnAndRideBlobman()
	-- 게임 내 블롭맨 소환 도구(Tool)나 상호작용 객체 소환을 시뮬레이션
	local foundBlobman = Workspace:FindFirstChild("Blobman") or Workspace:FindFirstChild("Blob")
	
	if not foundBlobman then
		-- 블롭맨이 없을 경우 생성
		local dummy = Instance.new("Part")
		dummy.Name = "Blobman"
		dummy.Size = Vector3.new(3, 5, 3)
		dummy.Position = rootPart.Position + Vector3.new(0, 2, 0)
		dummy.Parent = Workspace
		foundBlobman = dummy
	end
	
	-- 블롭맨에 탑승
	if character and character:FindFirstChild("Humanoid") and foundBlobman then
		local seat = foundBlobman:FindFirstChildOfClass("Seat")
		if seat then
			seat:Sit(character.Humanoid)
		else
			-- 시트가 없으면 캐릭터 위치를 블롭맨 위에 고정
			character:SetPrimaryPartCFrame(foundBlobman.CFrame + Vector3.new(0, 3, 0))
		end
	end
	
	return foundBlobman
end

-- 루프킬 토글
loopKillBtn.MouseButton1Click:Connect(function()
	enabled = not enabled
	if enabled then
		loopKillBtn.Text = "루프킬: ON"
		loopKillBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 50)
	else
		loopKillBtn.Text = "루프킬: OFF"
		loopKillBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
	end
end)

-- 루프킬 실행 로직
RunService.Heartbeat:Connect(function()
	if enabled and targetPlayer and targetPlayer.Character then
		local targetHrp = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
		
		if targetHrp then
			-- 블롭맨을 소환하고 타고 이동하는 함수 호출
			local blob = spawnAndRideBlobman()
			
			-- 대상과 캐릭터(블롭맨 탑승 상태)의 위치를 강제로 겹침 (루프 킬)
			if blob then
				blob.CFrame = targetHrp.CFrame
			else
				rootPart.CFrame = targetHrp.CFrame
			end
		end
	end
end)
